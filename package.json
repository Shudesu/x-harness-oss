{
  "name": "x-harness-oss",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Open-source X (Twitter) CRM/marketing automation — Xステップ代替",
  "scripts": {
    "dev:worker": "pnpm --filter worker dev",
    "build": "pnpm -r build",
    "deploy:worker": "pnpm --filter worker deploy",
    "db:migrate": "wrangler d1 execute x-harness --file=packages/db/schema.sql",
    "db:migrate:local": "wrangler d1 execute x-harness --file=packages/db/schema.sql --local",
    "db:migrate:004": "wrangler d1 execute x-harness --file=packages/db/migrations/004-polling-columns.sql",
    "db:migrate:004:local": "wrangler d1 execute x-harness --file=packages/db/migrations/004-polling-columns.sql --local",
    "db:migrate:005": "wrangler d1 execute x-harness --file=packages/db/migrations/005-reply-trigger.sql",
    "db:migrate:005:local": "wrangler d1 execute x-harness --file=packages/db/migrations/005-reply-trigger.sql --local",
    "test": "vitest run",
    "test:cubelic": "vitest run packages/content-os/src apps/worker/src/cubelic",
    "test:d1": "vitest run --config vitest.integration.config.ts",
    "test:contracts": "vitest run packages/schemas/src/contracts.test.ts",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "check:boundaries": "node scripts/check-phase1-boundaries.mjs",
    "check:config": "node scripts/check-config-sync.mjs",
    "security:scan": "node scripts/check-no-secrets.mjs",
    "preflight:production": "node scripts/preflight-production.mjs",
    "smoke:staging": "node scripts/smoke-staging.mjs",
    "validate:production-inputs": "pnpm --filter @x-harness/schemas validate:inputs",
    "check": "pnpm check:boundaries && pnpm check:config && pnpm security:scan && pnpm typecheck && pnpm test && pnpm test:d1 && pnpm build"
  },
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": "2.0.11",
      "postcss": "8.5.10",
      "sharp": "0.35.3"
    }
  },
  "devDependencies": {
    "miniflare": "3.20250718.3",
    "typescript": "^5.9.3",
    "vitest": "4.1.2"
  },
  "license": "MIT"
}
