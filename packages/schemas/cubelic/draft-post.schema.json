{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cubelic-fan.com/schemas/content-os/draft-post.v1.json",
  "title": "CUBΣLIC Draft Post v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["draft_id", "content_id", "account_id", "text", "media_asset_ids", "category", "template_id", "template_version", "variant", "target_stage", "hashtags", "destination_url", "quality_score", "freshness_score", "rights_gate", "approval_status", "idempotency_key", "created_at", "updated_at"],
  "properties": {
    "draft_id": { "type": "string" },
    "content_id": { "type": "string" },
    "account_id": { "const": "tubelic_cube" },
    "text": { "type": "string", "minLength": 1, "maxLength": 280 },
    "media_asset_ids": { "type": "array", "items": { "type": "string" } },
    "category": { "type": "string" },
    "template_id": { "type": "string" },
    "template_version": { "type": "string" },
    "variant": { "enum": ["a", "b", "c"] },
    "target_stage": { "type": "string" },
    "emotion_tags": { "type": "array", "items": { "type": "string" } },
    "hashtags": { "type": "array", "maxItems": 3, "items": { "type": "string" } },
    "destination_url": { "type": "string", "format": "uri" },
    "utm": { "type": "object" },
    "quality_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "quality_breakdown": { "type": "object" },
    "freshness_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "rights_gate": { "enum": ["passed", "not_applicable"] },
    "approval_status": { "enum": ["pending_review", "needs_revision", "rejected", "approved", "handed_off"] },
    "risks": { "type": "array", "items": { "type": "string" } },
    "human_review_required": { "type": "array", "items": { "type": "string" } },
    "idempotency_key": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "scheduled_at": { "type": "null" },
    "published_post_id": { "type": "null" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
