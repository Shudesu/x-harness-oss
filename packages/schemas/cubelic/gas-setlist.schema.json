{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cubelic-fan.com/schemas/contracts/gas-setlist.v1.json",
  "title": "GAS Setlist Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "event_id", "event_title", "venue", "starts_at", "ends_at", "lp_url", "confirmed_at", "confirmed_by", "songs"],
  "properties": {
    "schema_version": { "const": "cubelic.gas-setlist.v1" },
    "event_id": { "type": "string" },
    "event_title": { "type": "string", "minLength": 1 },
    "venue": { "type": "string", "minLength": 1 },
    "starts_at": { "type": "string", "format": "date-time" },
    "ends_at": { "type": "string", "format": "date-time" },
    "lp_url": { "type": "string", "format": "uri", "pattern": "^https://" },
    "confirmed_at": { "type": "string", "format": "date-time" },
    "confirmed_by": { "type": "string", "minLength": 1 },
    "songs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["position", "song_id", "title"],
        "properties": {
          "position": { "type": "integer", "minimum": 1 },
          "song_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
