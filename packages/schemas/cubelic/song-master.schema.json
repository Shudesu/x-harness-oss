{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cubelic-fan.com/schemas/contracts/song-master.v1.json",
  "title": "CUBΣLIC Song Master Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "songs"],
  "properties": {
    "schema_version": { "const": "cubelic.song-master.v1" },
    "generated_at": { "type": "string", "format": "date-time" },
    "songs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["song_id", "title", "aliases", "active"],
        "properties": {
          "song_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "aliases": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "active": { "type": "boolean" }
        }
      }
    }
  }
}
